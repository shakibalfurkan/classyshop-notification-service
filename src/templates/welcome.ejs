<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <meta name="color-scheme" content="light dark"/>
  <meta name="supported-color-schemes" content="light dark"/>
  <title>Welcome to ClassyShop!</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Roboto',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background-color:#F8FAFF;-webkit-font-smoothing:antialiased}
    a{text-decoration:none}
    img{border:0;display:block}

    .wrapper{width:100%;background:#F8FAFF;padding:48px 16px}
    .container{max-width:580px;margin:0 auto;background:#FFFFFF;border-radius:20px;overflow:hidden;border:1px solid #E2EAFF;box-shadow:0 4px 24px rgba(37,99,235,0.08)}

    /* Header */
    .header{background-color:#2563EB;padding:28px 40px;text-align:center}

    /* Hero */
    .hero{background:linear-gradient(160deg,#1D4ED8 0%,#2563EB 100%);padding:24px 40px 40px;text-align:center}
    .hero-emoji{font-size:44px;margin-bottom:14px;display:block;line-height:1}
    .hero-title{font-family:'Poppins','Roboto',sans-serif;font-size:28px;font-weight:700;color:#fff;line-height:1.3;letter-spacing:-0.5px;margin-bottom:8px}
    .hero-sub{font-size:14px;color:rgba(255,255,255,0.78);line-height:1.6}

    /* Body */
    .body{padding:40px 40px 32px}
    .greeting{font-size:16px;color:#0F172A;margin-bottom:8px;line-height:1.6}
    .greeting strong{font-weight:700;color:#0F172A}
    .text{font-size:14px;color:#64748B;line-height:1.85;margin-bottom:32px}

    /* Feature grid */
    .features{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:36px}
    .feature{background:#F8FAFF;border:1px solid #E2EAFF;border-radius:12px;padding:18px 16px}
    .feature-icon{font-size:26px;margin-bottom:10px;display:block;line-height:1}
    .feature-title{font-family:'Poppins','Roboto',sans-serif;font-size:13px;font-weight:600;color:#0F172A;margin-bottom:5px;line-height:1.3}
    .feature-desc{font-size:12px;color:#64748B;line-height:1.65}

    /* CTA */
    .cta-wrap{text-align:center;margin-bottom:36px}
    .cta-btn{display:inline-block;background:#2563EB;color:#fff;font-family:'Poppins','Roboto',sans-serif;font-size:15px;font-weight:600;padding:15px 44px;border-radius:10px;letter-spacing:0.2px}
    .cta-btn:hover{background:#1D4ED8}

    /* Signoff */
    .signoff{font-size:14px;color:#64748B;line-height:1.8}
    .signoff strong{color:#0F172A;font-weight:600}

    /* Footer */
    .footer{background:#F8FAFF;border-top:1px solid #E2EAFF;padding:24px 40px;text-align:center}
    .footer-links{margin-bottom:12px}
    .footer-link{font-size:12px;color:#2563EB;font-weight:500;margin:0 8px}
    .footer-info{font-size:12px;color:#94A3B8;line-height:1.8}
    .footer-info a{color:#2563EB;font-weight:500}
    .copyright{margin-top:10px;font-size:11px;color:#CBD5E1}

    @media(prefers-color-scheme:dark){
      body,.wrapper{background-color:#0B1120!important}
      .container{background:#131E35!important;border-color:rgba(255,255,255,0.08)!important;box-shadow:0 4px 24px rgba(0,0,0,0.4)!important}
      .greeting{color:#F1F5F9!important}
      .greeting strong{color:#F1F5F9!important}
      .text{color:#94A3B8!important}
      .feature{background:#1A2744!important;border-color:rgba(255,255,255,0.07)!important}
      .feature-title{color:#F1F5F9!important}
      .feature-desc{color:#64748B!important}
      .signoff{color:#94A3B8!important}
      .signoff strong{color:#F1F5F9!important}
      .footer{background:#0F1929!important;border-color:rgba(255,255,255,0.07)!important}
      .footer-link{color:#3B82F6!important}
      .footer-info{color:#475569!important}
      .footer-info a{color:#3B82F6!important}
      .copyright{color:#1E293B!important}
    }
    @media(max-width:600px){
      .body,.header,.hero,.footer{padding-left:24px!important;padding-right:24px!important}
      .features{grid-template-columns:1fr!important}
      .hero-title{font-size:24px!important}
    }
  </style>
</head>
<body>
<div class="wrapper">
<div class="container">

  <div class="header">
    <img src="https://res.cloudinary.com/duz75d1fh/image/upload/v1774184955/classyshop-logo-White-no-bg_yslre0.png"
         alt="ClassyShop" width="160" height="42"
         style="display:block;margin:0 auto;border:0;max-width:100%;height:auto"/>
  </div>

  <div class="hero">
    <span class="hero-emoji">🎉</span>
    <div class="hero-title">Welcome to ClassyShop!</div>
    <div class="hero-sub">Your account is verified and ready to go</div>
  </div>

  <div class="body">
    <p class="greeting">Hi, <strong><%= userName %></strong> 👋</p>
    <p class="text">
      We're thrilled to have you with us. You now have access to thousands of products
      from our verified vendors — electronics, fashion, home &amp; living, beauty, and more, all in one place.
    </p>

    <div class="features">
      <div class="feature">
        <span class="feature-icon">🎁</span>
        <div class="feature-title">Exclusive Offers</div>
        <div class="feature-desc">Member-only deals, flash sales, and early bird discounts.</div>
      </div>
      <div class="feature">
        <span class="feature-icon">⚡</span>
        <div class="feature-title">Fast Checkout</div>
        <div class="feature-desc">Save your info for lightning-fast one-click purchases.</div>
      </div>
      <div class="feature">
        <span class="feature-icon">📦</span>
        <div class="feature-title">Order Tracking</div>
        <div class="feature-desc">Real-time tracking with instant delivery updates.</div>
      </div>
      <div class="feature">
        <span class="feature-icon">💝</span>
        <div class="feature-title">Wishlist</div>
        <div class="feature-desc">Save items and get notified when they go on sale.</div>
      </div>
    </div>

    <div class="cta-wrap">
      <a href="https://classyshop.com/shop" class="cta-btn">Start Shopping Now →</a>
    </div>

    <p class="signoff">
      Happy shopping!<br/>
      <strong>The ClassyShop Team</strong>
    </p>
  </div>

  <div class="footer">
    <div class="footer-links">
      <a href="https://classyshop.com/shop" class="footer-link">Shop Now</a>
      <a href="https://classyshop.com/help" class="footer-link">Help Center</a>
      <a href="https://classyshop.com/track" class="footer-link">Track Order</a>
    </div>
    <div class="footer-info">
      <a href="mailto:support@classyshop.com">support@classyshop.com</a>
      &nbsp;·&nbsp; +880 1813 333 333 &nbsp;·&nbsp; Dhaka, Bangladesh
    </div>
    <p class="copyright">
      © <%= new Date().getFullYear() %> ClassyShop. All rights reserved. &nbsp;·&nbsp;
      <a href="#" style="color:#CBD5E1">Unsubscribe</a> &nbsp;·&nbsp;
      <a href="#" style="color:#CBD5E1">Privacy Policy</a>
    </p>
  </div>

</div>
</div>
</body>
</html>
