<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="color-scheme" content="light dark" />
  <meta name="supported-color-schemes" content="light dark" />

  <title>Verify Your Email — ClassyShop</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box
    }

    body {
      font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background-color: #F8FAFF;
      -webkit-font-smoothing: antialiased
    }

    a {
      text-decoration: none
    }

    img {
      border: 0;
      display: block
    }

    .wrapper {
      width: 100%;
      background: #F8FAFF;
      padding: 48px 16px
    }

    .container {
      max-width: 580px;
      margin: 0 auto;
      background: #FFFFFF;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid #E2EAFF;
      box-shadow: 0 4px 24px rgba(37, 99, 235, 0.08)
    }

    /* ── Header ── */
    .header {
      background-color: #2563EB;
      padding: 28px 40px;
      text-align: center
    }

    /* ── Hero ── */
    .hero {
      background: linear-gradient(160deg, #1D4ED8 0%, #2563EB 100%);
      padding: 8px 40px 36px;
      text-align: center
    }

    .badge {
      display: inline-block;
      background: rgba(255, 255, 255, 0.14);
      color: #fff;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 18px;
      border-radius: 100px;
      margin-bottom: 16px
    }

    .hero-title {
      font-family: 'Poppins', 'Roboto', sans-serif;
      font-size: 26px;
      font-weight: 700;
      color: #fff;
      line-height: 1.3;
      letter-spacing: -0.4px
    }

    /* ── Seller accent strip (only shown for seller) ── */
    .seller-strip {
      background: #EFF3FF;
      border-bottom: 1px solid #DBEAFE;
      padding: 12px 40px;
      display: flex;
      align-items: center;
      gap: 10px
    }

    .seller-badge {
      background: #2563EB;
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 6px;
      flex-shrink: 0
    }

    .seller-strip-text {
      font-size: 12px;
      color: #1E40AF;
      line-height: 1.5
    }

    /* ── Body ── */
    .body {
      padding: 40px 40px 32px
    }

    .greeting {
      font-size: 16px;
      color: #0F172A;
      margin-bottom: 8px;
      line-height: 1.6
    }

    .greeting strong {
      font-weight: 700;
      color: #0F172A
    }

    .text {
      font-size: 14px;
      color: #64748B;
      line-height: 1.85;
      margin-bottom: 32px
    }

    /* ── OTP ── */
    .otp-label {
      font-size: 10px;
      font-weight: 600;
      color: #94A3B8;
      letter-spacing: 2px;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 12px
    }

    .otp-box {
      background: #F0F5FF;
      border: 1.5px dashed #93C5FD;
      border-radius: 14px;
      padding: 28px 20px;
      text-align: center;
      margin-bottom: 12px
    }

    .otp-code {
      font-family: 'Courier New', monospace;
      font-size: 46px;
      font-weight: 700;
      color: #2563EB;
      letter-spacing: 16px;
      line-height: 1
    }

    .otp-expiry {
      text-align: center;
      font-size: 12px;
      color: #94A3B8;
      margin-bottom: 32px
    }

    .otp-expiry span {
      color: #DC2626;
      font-weight: 600
    }

    /* ── Divider ── */
    .divider {
      height: 1px;
      background: #EFF3FF;
      margin: 0 0 28px
    }

    /* ── Steps ── */
    .section-label {
      font-size: 10px;
      font-weight: 600;
      color: #94A3B8;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 16px
    }

    .step-row {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 14px
    }

    .step-num {
      flex-shrink: 0;
      width: 26px;
      height: 26px;
      background: #2563EB;
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 2px
    }

    .step-text {
      font-size: 13px;
      color: #64748B;
      line-height: 1.6;
      padding-top: 4px
    }

    /* ── Warning box ── */
    .warning-box {
      background: #FFFBEB;
      border-left: 3px solid #F59E0B;
      border-radius: 0 10px 10px 0;
      padding: 14px 18px;
      margin-top: 24px
    }

    .warning-box p {
      font-size: 13px;
      color: #92400E;
      line-height: 1.6
    }

    .warning-box strong {
      font-weight: 600
    }

    /* ── Footer ── */
    .footer {
      background: #F8FAFF;
      border-top: 1px solid #E2EAFF;
      padding: 24px 40px;
      text-align: center
    }

    .footer-links {
      margin-bottom: 12px
    }

    .footer-link {
      font-size: 12px;
      color: #2563EB;
      font-weight: 500;
      margin: 0 8px
    }

    .footer-info {
      font-size: 12px;
      color: #94A3B8;
      line-height: 1.8
    }

    .footer-info a {
      color: #2563EB;
      font-weight: 500
    }

    .copyright {
      margin-top: 10px;
      font-size: 11px;
      color: #CBD5E1
    }

    /* ── Dark mode ── */
    @media(prefers-color-scheme:dark) {

      body,
      .wrapper {
        background-color: #0B1120 !important
      }

      .container {
        background: #131E35 !important;
        border-color: rgba(255, 255, 255, 0.08) !important;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4) !important
      }

      .seller-strip {
        background: #1A2744 !important;
        border-color: rgba(255, 255, 255, 0.07) !important
      }

      .seller-strip-text {
        color: #93C5FD !important
      }

      .greeting {
        color: #F1F5F9 !important
      }

      .greeting strong {
        color: #F1F5F9 !important
      }

      .text {
        color: #94A3B8 !important
      }

      .otp-box {
        background: #1A2744 !important;
        border-color: rgba(59, 130, 246, 0.3) !important
      }

      .otp-code {
        color: #3B82F6 !important
      }

      .otp-expiry {
        color: #475569 !important
      }

      .divider {
        background: rgba(255, 255, 255, 0.06) !important
      }

      .section-label {
        color: #334155 !important
      }

      .step-text {
        color: #64748B !important
      }

      .warning-box {
        background: #1C1505 !important;
        border-color: #D97706 !important
      }

      .warning-box p {
        color: #FDE68A !important
      }

      .footer {
        background: #0F1929 !important;
        border-color: rgba(255, 255, 255, 0.07) !important
      }

      .footer-link {
        color: #3B82F6 !important
      }

      .footer-info {
        color: #475569 !important
      }

      .footer-info a {
        color: #3B82F6 !important
      }

      .copyright {
        color: #1E293B !important
      }
    }

    @media(max-width:600px) {

      .body,
      .header,
      .hero,
      .footer,
      .seller-strip {
        padding-left: 24px !important;
        padding-right: 24px !important
      }

      .otp-code {
        font-size: 36px !important;
        letter-spacing: 10px !important
      }

      .hero-title {
        font-size: 22px !important
      }
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <div class="container">

      <!-- Header — always blue, logo always white -->
      <div class="header">
        <img src="https://res.cloudinary.com/duz75d1fh/image/upload/v1774184955/classyshop-logo-White-no-bg_yslre0.png"
          alt="ClassyShop" width="160" height="42"
          style="display:block;margin:0 auto;border:0;max-width:100%;height:auto" />
      </div>

      <!-- Hero -->
      <div class="hero">
        <div class="badge">Email Verification</div>
        <div class="hero-title">Confirm your email address</div>
      </div>

      <%# Seller-only accent strip — tells sellers they're on the right path %>
        <% if (userType==='seller' ) { %>
          <div class="seller-strip">
            <span class="seller-badge">Seller</span>
            <span class="seller-strip-text">You're applying to become a verified ClassyShop seller</span>
          </div>
          <% } %>

            <!-- Body -->
            <div class="body">

              <p class="greeting">Hi, <strong>
                  <%= userName %>
                </strong> 👋</p>

              <%# Intro paragraph — context-aware based on userType %>
                <% if (userType==='seller' ) { %>
                  <p class="text">
                    Thank you for applying to sell on ClassyShop! Before we review your seller application,
                    we need to verify your email address. Enter the code below to confirm your email
                    and move forward with the onboarding process.
                  </p>
                  <% } else { %>
                    <p class="text">
                      Welcome to ClassyShop! You're one step away from accessing thousands of products
                      from our verified sellers. Use the code below to verify your email and activate your account.
                    </p>
                    <% } %>

                      <!-- OTP block — same for both -->
                      <p class="otp-label">Your verification code</p>
                      <div class="otp-box">
                        <div class="otp-code">
                          <%= otp %>
                        </div>
                      </div>
                      <p class="otp-expiry">Expires in <span>10 minutes</span> &nbsp;·&nbsp; Do not share this code</p>

                      <div class="divider"></div>

                      <!-- Steps — last step is dynamic -->
                      <p class="section-label">What's next</p>
                      <div class="step-row">
                        <div class="step-num">1</div>
                        <p class="step-text">Copy the 6-digit code above</p>
                      </div>
                      <div class="step-row">
                        <div class="step-num">2</div>
                        <p class="step-text">Paste it into the verification field on the sign-up page</p>
                      </div>
                      <div class="step-row">
                        <div class="step-num">3</div>
                        <% if (userType==='seller' ) { %>
                          <p class="step-text">Complete your seller profile and start selling</p>
                          <% } else { %>
                            <p class="step-text">Start shopping or explore thousands of products from verified sellers
                            </p>
                            <% } %>
                      </div>

                      <!-- Warning note — same for both -->
                      <div class="warning-box">
                        <p>
                          <strong>Didn't create an account?</strong>
                          Safely ignore this email — no action is needed on your end.
                        </p>
                      </div>

            </div>

            <!-- Footer -->
            <div class="footer">
              <div class="footer-links">
                <a href="https://classyshop.com/shop" class="footer-link">Shop Now</a>
                <a href="https://classyshop.com/help" class="footer-link">Help Center</a>
                <a href="https://classyshop.com/contact" class="footer-link">Contact</a>
              </div>
              <div class="footer-info">
                <a href="mailto:support@classyshop.com">support@classyshop.com</a>
                &nbsp;·&nbsp; +880 1813 333 333 &nbsp;·&nbsp; Dhaka, Bangladesh
              </div>
              <p class="copyright">
                © <%= new Date().getFullYear() %> ClassyShop. All rights reserved.
                  &nbsp;·&nbsp; <a href="#" style="color:#CBD5E1">Unsubscribe</a>
                  &nbsp;·&nbsp; <a href="#" style="color:#CBD5E1">Privacy Policy</a>
              </p>
            </div>

    </div>
  </div>
</body>

</html>