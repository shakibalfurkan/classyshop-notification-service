<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <meta name="color-scheme" content="light dark"/>
  <meta name="supported-color-schemes" content="light dark"/>
  <title>Reset Your Password — ClassyShop</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Roboto',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background-color:#F8FAFF;-webkit-font-smoothing:antialiased}
    a{text-decoration:none}
    img{border:0;display:block}

    .wrapper{width:100%;background:#F8FAFF;padding:48px 16px}
    .container{max-width:580px;margin:0 auto;background:#FFFFFF;border-radius:20px;overflow:hidden;border:1px solid #E2EAFF;box-shadow:0 4px 24px rgba(37,99,235,0.08)}

    /* Header */
    .header{background-color:#2563EB;padding:28px 40px;text-align:center}

    /* Hero — amber/orange for password reset = caution, not danger */
    .hero{background:linear-gradient(160deg,#92400E 0%,#D97706 100%);padding:8px 40px 36px;text-align:center}
    .badge{display:inline-block;background:rgba(255,255,255,0.18);color:#fff;font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:6px 18px;border-radius:100px;margin-bottom:16px}
    .hero-title{font-family:'Poppins','Roboto',sans-serif;font-size:26px;font-weight:700;color:#fff;line-height:1.3;letter-spacing:-0.4px}

    /* Body */
    .body{padding:40px 40px 32px}
    .greeting{font-size:16px;color:#0F172A;margin-bottom:8px;line-height:1.6}
    .greeting strong{font-weight:700;color:#0F172A}
    .text{font-size:14px;color:#64748B;line-height:1.85;margin-bottom:32px}

    /* OTP */
    .otp-label{font-size:10px;font-weight:600;color:#94A3B8;letter-spacing:2px;text-transform:uppercase;text-align:center;margin-bottom:12px}
    .otp-box{background:#FFFBEB;border:1.5px dashed #F59E0B;border-radius:14px;padding:28px 20px;text-align:center;margin-bottom:12px}
    .otp-code{font-family:'Courier New',monospace;font-size:46px;font-weight:700;color:#D97706;letter-spacing:16px;line-height:1}
    .otp-expiry{text-align:center;font-size:12px;color:#94A3B8;margin-bottom:32px}
    .otp-expiry span{color:#DC2626;font-weight:600}

    /* Divider */
    .divider{height:1px;background:#EFF3FF;margin:0 0 28px}

    /* Warning */
    .alert{background:#FFF7ED;border:1.5px solid #FED7AA;border-radius:12px;padding:18px 20px;margin-bottom:24px}
    .alert-head{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:#C2410C;margin-bottom:8px}
    .alert p{font-size:13px;color:#9A3412;line-height:1.7}
    .alert strong{font-weight:600}

    /* Info note */
    .info-note{background:#F8FAFF;border-radius:12px;border:1px solid #E2EAFF;padding:16px 20px;text-align:center}
    .info-note p{font-size:13px;color:#475569;line-height:1.6}
    .info-note a{color:#2563EB;font-weight:600}

    /* Footer */
    .footer{background:#F8FAFF;border-top:1px solid #E2EAFF;padding:24px 40px;text-align:center}
    .footer-info{font-size:12px;color:#94A3B8;line-height:1.8}
    .footer-info a{color:#2563EB;font-weight:500}
    .copyright{margin-top:10px;font-size:11px;color:#CBD5E1}

    @media(prefers-color-scheme:dark){
      body,.wrapper{background-color:#0B1120!important}
      .container{background:#131E35!important;border-color:rgba(255,255,255,0.08)!important;box-shadow:0 4px 24px rgba(0,0,0,0.4)!important}
      .greeting{color:#F1F5F9!important}
      .greeting strong{color:#F1F5F9!important}
      .text{color:#94A3B8!important}
      .otp-box{background:#1C1505!important;border-color:rgba(245,158,11,0.35)!important}
      .otp-code{color:#F59E0B!important}
      .otp-expiry{color:#475569!important}
      .divider{background:rgba(255,255,255,0.06)!important}
      .alert{background:#1C0E05!important;border-color:rgba(251,146,60,0.2)!important}
      .alert-head{color:#FED7AA!important}
      .alert p{color:#FDBA74!important}
      .info-note{background:#1A2744!important;border-color:rgba(255,255,255,0.07)!important}
      .info-note p{color:#94A3B8!important}
      .info-note a{color:#3B82F6!important}
      .footer{background:#0F1929!important;border-color:rgba(255,255,255,0.07)!important}
      .footer-info{color:#475569!important}
      .footer-info a{color:#3B82F6!important}
      .copyright{color:#1E293B!important}
    }
    @media(max-width:600px){
      .body,.header,.hero,.footer{padding-left:24px!important;padding-right:24px!important}
      .otp-code{font-size:36px!important;letter-spacing:10px!important}
      .hero-title{font-size:22px!important}
    }
  </style>
</head>
<body>
<div class="wrapper">
<div class="container">

  <div class="header">
    <img src="https://res.cloudinary.com/duz75d1fh/image/upload/v1774184955/classyshop-logo-White-no-bg_yslre0.png"
         alt="ClassyShop" width="160" height="42"
         style="display:block;margin:0 auto;border:0;max-width:100%;height:auto"/>
  </div>

  <!-- Amber hero — caution color, not danger red -->
  <div class="hero">
    <div class="badge">Password Reset</div>
    <div class="hero-title">Reset your password</div>
  </div>

  <div class="body">
    <p class="greeting">Hi, <strong><%= userName %></strong></p>
    <p class="text">
      We received a request to reset the password for your ClassyShop account.
      Use the code below to proceed. If you didn't request this, you can safely ignore this email
      — your password will remain unchanged.
    </p>

    <p class="otp-label">Your password reset code</p>
    <div class="otp-box">
      <div class="otp-code"><%= otp %></div>
    </div>
    <p class="otp-expiry">Expires in <span>15 minutes</span> &nbsp;·&nbsp; Single use only</p>

    <div class="divider"></div>

    <div class="alert">
      <div class="alert-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" style="flex-shrink:0">
          <circle cx="12" cy="12" r="10" stroke="#C2410C" stroke-width="2"/>
          <path d="M12 8v4m0 4h.01" stroke="#C2410C" stroke-width="2" stroke-linecap="round"/>
        </svg>
        Security notice
      </div>
      <p>If you didn't request a password reset, <strong>ignore this email</strong> and your account will stay secure. Consider changing your password if you're concerned about unauthorized access.</p>
    </div>

    <div class="info-note">
      <p>Need help? <a href="mailto:support@classyshop.com">Contact our support team</a> — we're here 24/7.</p>
    </div>
  </div>

  <div class="footer">
    <div class="footer-info">
      <a href="mailto:support@classyshop.com">support@classyshop.com</a>
      &nbsp;·&nbsp; +880 1813 333 333 &nbsp;·&nbsp; Dhaka, Bangladesh
    </div>
    <p class="copyright">
      © <%= new Date().getFullYear() %> ClassyShop. All rights reserved. &nbsp;·&nbsp;
      <a href="#" style="color:#CBD5E1">Unsubscribe</a> &nbsp;·&nbsp;
      <a href="#" style="color:#CBD5E1">Privacy Policy</a>
    </p>
  </div>

</div>
</div>
</body>
</html>
